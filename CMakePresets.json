{
  "version": 3,
  "configurePresets": [
    {
      "name": "mingw-debug",
      "displayName": "MinGW Debug",
      "generator": "Ninja",
      "binaryDir": "${sourceDir}/out/build/${presetName}",
      "installDir": "${sourceDir}/out/install/${presetName}",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug",
        "CMAKE_C_COMPILER": "x86_64-w64-mingw32-gcc",
        "CMAKE_CXX_COMPILER": "x86_64-w64-mingw32-g++",
        "CMAKE_PREFIX_PATH": "C:/Qt/6.11.0/llvm-mingw_64",
        "CFITSIO_INCLUDE_DIRS": "${sourceDir}/vcpkg_installed/x64-windows/include/cfitsio",
        "CFITSIO_LIBRARIES": "${sourceDir}/vcpkg_installed/x64-windows/bin/cfitsio.dll"
      },
      "environment": {
        "PATH": "C:/Qt/Tools/llvm-mingw1706_64/bin;C:/Qt/Tools/CMake_64/bin;C:/Qt/Tools/Ninja;$penv{PATH}"
      },
      "vendor": {
        "microsoft.com/VisualStudioSettings/CMake/1.0": {
          "hostOS": [ "Windows" ],
          "intelliSenseMode": "linux-gcc-x64"
        }
      }
    },
    {
      "name": "mingw-release",
      "displayName": "MinGW Release",
      "inherits": "mingw-debug",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release"
      }
    }
  ],
  "buildPresets": [
    {
      "name": "mingw-debug",
      "configurePreset": "mingw-debug"
    },
    {
      "name": "mingw-release",
      "configurePreset": "mingw-release"
    }
  ]
}
